# ── etchmem-server configuration ──────────────────────────────────────────
# Copy to .env and fill in. All values have sane defaults except API keys.

# ── LLM cascade (Pydantic AI model strings; swap freely) ───────────────────
# Stage 2 — claim extraction (cheap/mini model).
ETCHMEM_CLAIM_MODEL=openai:gpt-5-mini
# Stage 3 — conflict resolution + narrative (most capable model).
ETCHMEM_ETCH_MODEL=openai:gpt-5.5
OPENAI_API_KEY=sk-...

# ── Embeddings (pluggable) ─────────────────────────────────────────────────
# "openai" (default) or "local" (sentence-transformers, offline) or "fake" (tests)
EMBEDDING_PROVIDER=openai
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
LOCAL_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── Storage ────────────────────────────────────────────────────────────────
# Directory holding left.duckdb (signals+claims) and right.duckdb (entities+etches).
ETCHMEM_DATA_DIR=/data

# ── Extensions ──────────────────────────────────────────────────────────────
# Folder of YAML files declaring extra properties to extract (e.g. sales_intent).
# Additive vocabulary; never overrides the core (entity, property, value) triple.
ETCHMEM_EXT_DIR=./ext

# ── Stage 1: signal dedup ──────────────────────────────────────────────────
# Cosine distance below which two raw signals are collapsed (provenance kept).
ETCHMEM_SIGNAL_DEDUP_DISTANCE=0.08

# ── Entity resolution ──────────────────────────────────────────────────────
# Cosine similarity above which two entity names are treated as the same entity.
ETCHMEM_ENTITY_SIM_THRESHOLD=0.86

# ── Consolidation / fold ───────────────────────────────────────────────────
# Properties allowed to hold multiple values at once (union, never a conflict).
ETCHMEM_MULTI_VALUE_PROPERTIES=tech_stack,integrations
# Optional per-source trust weights (JSON). A gap >= TRUST_GAP resolves conflicts.
ETCHMEM_SOURCE_TRUST_JSON={}
ETCHMEM_TRUST_GAP=0.3

# ── Worker (in-process; no external broker) ────────────────────────────────
ETCHMEM_WORKER_ENABLED=true
ETCHMEM_WORKER_INTERVAL_SECONDS=5
ETCHMEM_EXTRACT_MIN_BATCH=1
ETCHMEM_EXTRACT_MAX_WAIT_SECONDS=30

# ── Signal TTL ─────────────────────────────────────────────────────────────
ETCHMEM_SIGNAL_TTL_SECONDS=0

# ── Server ─────────────────────────────────────────────────────────────────
ETCHMEM_HOST=0.0.0.0
ETCHMEM_PORT=8000

# ── Stage-2 extraction throughput ───────────────────────────────────────────
# Signals combined into ONE extraction LLM call.
ETCHMEM_EXTRACT_LLM_BATCH_SIZE=6
# Extraction LLM calls in flight at once (raise carefully — 429 risk).
ETCHMEM_EXTRACT_CONCURRENCY=4
# Retries with exponential backoff on 429 / transient LLM errors.
ETCHMEM_LLM_MAX_RETRIES=4
